generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["primequote"]
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  password           String
  name               String
  role               String             @default("user")
  plan               String             @default("FREE")
  quotesCreatedCount Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  sessions           Session[]
  quotes             Quote[]
  profile            BusinessProfile?
  subscription       Subscription?
  pushSubscriptions  PushSubscription[]
  sectionTemplates   UserSectionTemplate[]
  quotePackages      UserQuotePackage[]

  @@schema("primequote")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model BusinessProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String?
  logoUrl        String?
  phone          String?
  email          String?
  website        String?
  address        String?
  taxId          String?
  paymentMethods String?
  conditions     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model Template {
  id          String            @id @default(cuid())
  name        String
  description String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  quotes      Quote[]
  sections    TemplateSection[]

  @@schema("primequote")
}

model TemplateSection {
  id           String             @id @default(cuid())
  templateId   String
  key          String
  title        String
  icon         String?
  order        Int                @default(0)
  isRequired   Boolean            @default(false)
  isDefault    Boolean            @default(true)
  content      String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  sectionItems QuoteSectionItem[]
  template     Template           @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model Quote {
  id              String             @id @default(cuid())
  token           String             @unique
  templateId      String
  userId          String
  companyName     String
  contactName     String?
  email           String?
  phone           String?
  projectName     String?
  internalNotes   String?
  projectPrice    Float?
  quoteType       String             @default("FIXED")
  percentageValue Float?
  currency        String             @default("USD")
  status          String             @default("draft")
  paymentLink     String?
  logoUrl         String?
  themeColor      String?            @default("default")
  validUntil      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  template        Template           @relation(fields: [templateId], references: [id])
  user            User               @relation(fields: [userId], references: [id])
  sections        QuoteSectionItem[]
  customSections  CustomSection[]
  images          QuoteImage[]
  messages        QuoteMessage[]
  contract        Contract?
  payments        Payment[]
  optionalSelections QuoteOptionalSelection[]

  @@schema("primequote")
}

model QuoteSectionItem {
  id                String          @id @default(cuid())
  quoteId           String
  templateSectionId String
  title             String
  content           String?
  order             Int             @default(0)
  isVisible         Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  templateSection   TemplateSection @relation(fields: [templateSectionId], references: [id])
  quote             Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model CustomSection {
  id       String  @id @default(cuid())
  quoteId  String
  title    String
  content  String?
  imageUrl String?
  order    Int     @default(0)
  quote    Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  optionalSelections QuoteOptionalSelection[]

  @@schema("primequote")
}

model QuoteOptionalSelection {
  id              String        @id @default(cuid())
  quoteId         String
  customSectionId String
  enabled         Boolean       @default(false)
  lockedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  quote           Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  customSection   CustomSection @relation(fields: [customSectionId], references: [id], onDelete: Cascade)

  @@unique([quoteId, customSectionId])
  @@schema("primequote")
}

model QuoteImage {
  id        String    @id @default(cuid())
  quoteId   String
  url       String
  filename  String
  size      Int
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  quote     Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model Branding {
  id           String   @id @default(cuid())
  logoUrl      String?
  companyName  String   @default("Eventos Prime Tecnología")
  primaryColor String   @default("#1a1a2e")
  accentColor  String   @default("#0f3460")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@schema("primequote")
}

model QuoteMessage {
  id        String   @id @default(cuid())
  quoteId   String
  sender    String
  type      String   @default("MESSAGE")
  text      String
  imageUrl  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model Contract {
  id        String    @id @default(cuid())
  quoteId   String    @unique
  content   String
  metadata  String?
  signature String?
  signedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  quote     Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model Payment {
  id            String   @id @default(cuid())
  quoteId       String
  amount        Float
  currency      String   @default("USD")
  status        String   @default("pending")
  paymentMethod String?
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String    @unique
  plan          String    @default("FREE")
  billingPeriod String?
  status        String    @default("active")
  provider      String?
  purchaseToken String?
  productId     String?
  expiresAt     DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  keys      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}

model AppVersion {
  id          String   @id @default(cuid())
  version     String
  title       String
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@schema("primequote")
}

model UserSectionTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String   @default("standard")
  title       String
  description String?
  imageUrl    String?
  buttonUrl   String?
  phoneNumber String?
  messageText String?
  hasPrice    Boolean  @default(false)
  price       Float?
  hasIva      Boolean  @default(false)
  ivaPercent  Float?   @default(15)
  includeInTotal Boolean @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageSections PackageSection[]

  @@schema("primequote")
}

model UserQuotePackage {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections    PackageSection[]

  @@schema("primequote")
}

model PackageSection {
  id         String   @id @default(cuid())
  packageId  String
  templateId String
  order      Int      @default(0)
  package    UserQuotePackage    @relation(fields: [packageId], references: [id], onDelete: Cascade)
  template   UserSectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@schema("primequote")
}
